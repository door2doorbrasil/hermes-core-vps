{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "$id": "https://example.local/schemas/emails.schema.json",
  "title": "Email",
  "description": "Registro de e-mails recebidos ou enviados.",
  "required": [
    "id",
    "direction",
    "message_id",
    "subject",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "direction": {
      "type": "string",
      "enum": [
        "incoming",
        "outgoing"
      ]
    },
    "message_id": {
      "type": "string",
      "minLength": 1
    },
    "thread_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "from": {
      "type": [
        "string",
        "null"
      ]
    },
    "to": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "cc": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "bcc": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "subject": {
      "type": "string"
    },
    "sent_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "received_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "body_text": {
      "type": [
        "string",
        "null"
      ]
    },
    "body_html_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "raw_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "supplier_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "contact_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "attachment_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "classification": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "processed",
        "failed",
        "ignored"
      ]
    },
    "hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "source": {
      "type": "string",
      "default": "imap"
    },
    "version": {
      "type": "string",
      "default": "0.1.0"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
