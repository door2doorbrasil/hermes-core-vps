{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "$id": "https://example.local/schemas/fornecedores.schema.json",
  "title": "Fornecedor",
  "description": "Cadastro de fornecedores.",
  "required": [
    "id",
    "name",
    "status",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "legal_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "tax_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "emails": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "phones": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "website": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "prospect",
        "blocked"
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "notes": {
      "type": "string",
      "default": ""
    },
    "source": {
      "type": "string",
      "default": "manual"
    },
    "version": {
      "type": "string",
      "default": "0.1.0"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
