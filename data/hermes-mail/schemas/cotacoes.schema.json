{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "$id": "https://example.local/schemas/cotacoes.schema.json",
  "title": "Cotação",
  "description": "Cotação recebida ou emitida.",
  "required": [
    "id",
    "supplier_id",
    "email_id",
    "items",
    "currency",
    "status",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "supplier_id": {
      "type": "string",
      "minLength": 1
    },
    "contact_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "email_id": {
      "type": "string",
      "minLength": 1
    },
    "quote_number": {
      "type": [
        "string",
        "null"
      ]
    },
    "requested_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "received_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "currency": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "description",
          "quantity",
          "unit",
          "unit_price",
          "subtotal"
        ],
        "properties": {
          "product_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "description": {
            "type": "string"
          },
          "quantity": {
            "type": "number"
          },
          "unit": {
            "type": "string"
          },
          "unit_price": {
            "type": "number"
          },
          "subtotal": {
            "type": "number"
          },
          "notes": {
            "type": "string",
            "default": ""
          }
        }
      },
      "default": []
    },
    "subtotal": {
      "type": "number"
    },
    "shipping": {
      "type": "number",
      "default": 0
    },
    "taxes": {
      "type": "number",
      "default": 0
    },
    "total": {
      "type": "number"
    },
    "valid_until": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "lead_time_days": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "received",
        "reviewing",
        "approved",
        "rejected",
        "expired"
      ]
    },
    "notes": {
      "type": "string",
      "default": ""
    },
    "source": {
      "type": "string",
      "default": "email"
    },
    "version": {
      "type": "string",
      "default": "0.1.0"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
