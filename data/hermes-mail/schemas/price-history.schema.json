{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "$id": "https://example.local/schemas/price-history.schema.json",
  "title": "Histórico de Preços",
  "description": "Registro histórico de preço por fornecedor e produto.",
  "required": [
    "id",
    "product_id",
    "supplier_id",
    "unit_price",
    "currency",
    "captured_at",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "product_id": {
      "type": "string",
      "minLength": 1
    },
    "supplier_id": {
      "type": "string",
      "minLength": 1
    },
    "quote_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "email_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "currency": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3
    },
    "unit_price": {
      "type": "number"
    },
    "quantity": {
      "type": [
        "number",
        "null"
      ]
    },
    "min_qty": {
      "type": [
        "number",
        "null"
      ]
    },
    "effective_date": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "default": "email"
    },
    "attachment_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "notes": {
      "type": "string",
      "default": ""
    },
    "version": {
      "type": "string",
      "default": "0.1.0"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
